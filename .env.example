# --- Shopify Storefront API ---
# Create a custom app in Shopify Admin > Settings > Apps and sales channels > Develop apps
# Enable the Storefront API and copy the public access token below.
NEXT_PUBLIC_SHOPIFY_DOMAIN=acidmath.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your-storefront-api-token
SHOPIFY_STOREFRONT_API_VERSION=2024-10

# Optional: scope the whole storefront to one curated collection (its handle,
# e.g. "current-drop") instead of showing every product in the store.
# Leave commented out to fetch the entire catalog.
# NEXT_PUBLIC_SHOPIFY_COLLECTION_HANDLE=current-drop

# --- Optional: Spotify embed for the Music/Gallery section ---
NEXT_PUBLIC_SPOTIFY_PLAYLIST_ID=37i9dQZF1DXc8kgYqQL7bR

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://acidmath.com
